# ============================================================
# AWS Signaling Server — .env
# ============================================================

# Yerel GPU Worker'ın Ngrok URL'si (her ngrok başlatmada güncelle)
# Örnek: https://abcd-1234-efgh.ngrok-free.app
GPU_WORKER_URL=http://127.0.0.1:8001

# ============================================================
# GPU Worker — .env  (gpu_worker/ dizinine de koy)
# ============================================================

# GPU Worker'ın dinleyeceği port
GPU_WORKER_PORT=8001

# ============================================================
# React Frontend — .env  (aws_server/frontend/ dizinine de koy)
# ============================================================

# AWS Signaling Server'ın WebSocket adresi
VITE_SIGNALING_WS_URL=wss://AWS_EC2_IP_VEYA_DOMAIN:8000
